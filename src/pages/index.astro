---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Instacheck</title>
	</head>
	<body>
		<main class="page" data-app-root data-view="summary">
			<header class="hero">
				<div class="hero__top">
					<div class="brand">
						<div class="brand__mark" aria-hidden="true">IC</div>
						<div class="brand__name">Instacheck</div>
					</div>
					<div class="hero__hint">All processing happens locally in your browser.</div>
				</div>
				<h1 class="hero__title">Visualize your Instagram export</h1>
				<p class="hero__subtitle">
					Upload the ZIP you downloaded from Instagram. We’ll find
					<code>connections/followers_and_following</code> and compute the diffs.
				</p>
				<div class="drop">
					<label class="drop__label">
						<input class="drop__input" data-zip-input type="file" accept=".zip,application/zip" />
						<span class="drop__cta">Choose export ZIP</span>
						<span class="drop__meta">.zip</span>
					</label>
					<div class="drop__status" data-status></div>
					<div class="drop__error" data-error></div>
				</div>
			</header>

			<section class="results" data-results>
				<nav class="nav">
					<a class="nav__link" href="#summary" data-nav-link="summary" aria-current="true">
						<span class="nav__label">Basic summary</span>
					</a>
					<a class="nav__link" href="#not-following-back" data-nav-link="not-following-back">
						<span class="nav__label">Not following back</span>
						<span class="nav__pill"><span data-count="not-following-back">0</span></span>
					</a>
					<a class="nav__link" href="#fans" data-nav-link="fans">
						<span class="nav__label">Fans (they follow you)</span>
						<span class="nav__pill"><span data-count="fans">0</span></span>
					</a>
					<a class="nav__link" href="#unfollowed" data-nav-link="unfollowed">
						<span class="nav__label">Unfollowed users</span>
						<span class="nav__pill"><span data-count="unfollowed">0</span></span>
					</a>
				</nav>

				<div class="panels">
					<section class="panel" data-panel="summary">
						<div class="panel__grid">
							<div class="stat">
								<div class="stat__label">Followers</div>
								<div class="stat__value" data-count="followers">—</div>
							</div>
							<div class="stat">
								<div class="stat__label">Following</div>
								<div class="stat__value" data-count="following">—</div>
							</div>
							<div class="stat">
								<div class="stat__label">Mutuals</div>
								<div class="stat__value" data-count="mutual">—</div>
							</div>
						</div>
					</section>

					<section class="panel" data-panel="not-following-back">
						<h2 class="panel__title">People you follow who don’t follow you back</h2>
						<ol class="list" data-list="not-following-back"></ol>
					</section>

					<section class="panel" data-panel="fans">
						<h2 class="panel__title">People who follow you but you don’t follow back</h2>
						<ol class="list" data-list="fans"></ol>
					</section>

					<section class="panel" data-panel="unfollowed">
						<h2 class="panel__title">Accounts you unfollowed (from export)</h2>
						<ol class="list" data-list="unfollowed"></ol>
					</section>
				</div>
			</section>

			<footer class="footer">
				<p class="footer__text">
					Expected files: <code>connections/followers_and_following/followers_1.json</code> and
					<code>connections/followers_and_following/following.json</code>.
				</p>
			</footer>
		</main>

		<script type="module" src="/src/scripts/app.js"></script>
	</body>
</html>

<style>
	:root {
		--bg: #07060a;
		--ink: rgba(255, 255, 255, 0.92);
		--muted: rgba(255, 255, 255, 0.68);
		--faint: rgba(255, 255, 255, 0.12);
		--faint2: rgba(255, 255, 255, 0.08);
		--edge: rgba(255, 255, 255, 0.18);
		--accent: #52ffd5;
		--accent2: #ff4dd8;
		--warn: #ff4d6d;
		--paper: rgba(255, 255, 255, 0.03);
		--paper2: rgba(255, 255, 255, 0.06);
		--shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
		--radius: 18px;
		--radius2: 26px;
		--mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New',
			monospace;
		--sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	html,
	body {
		height: 100%;
	}

	body {
		margin: 0;
		font-family: var(--sans);
		color: var(--ink);
		background: radial-gradient(1200px 600px at 16% 18%, rgba(82, 255, 213, 0.12), transparent 60%),
			radial-gradient(900px 540px at 84% 16%, rgba(255, 77, 216, 0.1), transparent 62%),
			radial-gradient(1100px 700px at 60% 90%, rgba(255, 77, 109, 0.08), transparent 60%),
			linear-gradient(180deg, #06050a 0%, #07060a 30%, #06060b 100%);
	}

	code {
		font-family: var(--mono);
		font-size: 0.92em;
		color: rgba(255, 255, 255, 0.86);
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		padding: 0.12rem 0.35rem;
		border-radius: 0.5rem;
	}

	.page {
		min-height: 100%;
		display: grid;
		grid-template-rows: auto 1fr auto;
	}

	.hero {
		padding: clamp(22px, 4vw, 52px) clamp(18px, 4vw, 56px) 22px;
		max-width: 1050px;
		width: 100%;
		margin: 0 auto;
	}

	.hero__top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 24px;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.brand__mark {
		width: 40px;
		height: 40px;
		border-radius: 14px;
		display: grid;
		place-items: center;
		font-weight: 800;
		letter-spacing: -0.08em;
		background: linear-gradient(135deg, rgba(82, 255, 213, 0.18), rgba(255, 77, 216, 0.16));
		border: 1px solid rgba(255, 255, 255, 0.14);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
	}

	.brand__name {
		font-weight: 760;
		letter-spacing: -0.035em;
	}

	.hero__hint {
		color: var(--muted);
		font-size: 0.95rem;
	}

	.hero__title {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.2rem);
		letter-spacing: -0.045em;
		line-height: 1.05;
	}

	.hero__subtitle {
		margin: 14px 0 0;
		color: var(--muted);
		max-width: 70ch;
		line-height: 1.5;
	}

	.drop {
		margin-top: 20px;
		padding: 14px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--radius2);
		box-shadow: var(--shadow);
		backdrop-filter: blur(10px);
	}

	.drop__label {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 10px;
		cursor: pointer;
		user-select: none;
	}

	.drop__input {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	.drop__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 14px;
		border-radius: 16px;
		background: linear-gradient(135deg, rgba(82, 255, 213, 0.14), rgba(255, 77, 216, 0.12));
		border: 1px solid rgba(255, 255, 255, 0.14);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.drop__meta {
		font-family: var(--mono);
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.72);
		padding: 8px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(0, 0, 0, 0.16);
	}

	.drop__status {
		margin-top: 10px;
		color: rgba(255, 255, 255, 0.75);
		font-size: 0.95rem;
		min-height: 1.2em;
	}

	.drop__error {
		margin-top: 8px;
		color: var(--warn);
		font-size: 0.95rem;
		line-height: 1.3;
		white-space: pre-wrap;
		display: none;
	}

	.drop__error[data-has-error] {
		display: block;
	}

	.results {
		max-width: 1050px;
		width: 100%;
		margin: 0 auto;
		padding: 18px clamp(18px, 4vw, 56px) clamp(34px, 5vw, 64px);
		display: none;
	}

	.results[data-has-results] {
		display: block;
	}

	.nav {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.nav__link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		color: rgba(255, 255, 255, 0.86);
		text-decoration: none;
		background: rgba(255, 255, 255, 0.04);
	}

	.nav__link[aria-current='true'] {
		border-color: rgba(82, 255, 213, 0.32);
		box-shadow: 0 0 0 2px rgba(82, 255, 213, 0.08);
		background: rgba(82, 255, 213, 0.06);
	}

	.nav__pill {
		font-family: var(--mono);
		font-size: 0.88rem;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(0, 0, 0, 0.2);
	}

	.panels {
		margin-top: 16px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--radius2);
		box-shadow: var(--shadow);
		overflow: hidden;
	}

	.panel {
		padding: clamp(14px, 2.5vw, 22px);
		display: none;
	}

	.page[data-view='summary'] .panel[data-panel='summary'] {
		display: block;
	}

	.page[data-view='not-following-back'] .panel[data-panel='not-following-back'] {
		display: block;
	}

	.page[data-view='fans'] .panel[data-panel='fans'] {
		display: block;
	}

	.page[data-view='unfollowed'] .panel[data-panel='unfollowed'] {
		display: block;
	}

	.panel__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 12px;
	}

	@media (max-width: 680px) {
		.hero__top {
			flex-direction: column;
			align-items: flex-start;
		}

		.panel__grid {
			grid-template-columns: 1fr;
		}
	}

	.stat {
		border-radius: var(--radius);
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(0, 0, 0, 0.14);
		padding: 14px 14px 16px;
	}

	.stat__label {
		color: rgba(255, 255, 255, 0.68);
		font-size: 0.95rem;
		letter-spacing: -0.01em;
	}

	.stat__value {
		margin-top: 10px;
		font-size: 2.1rem;
		letter-spacing: -0.05em;
		font-weight: 780;
	}

	.panel__title {
		margin: 0 0 12px;
		font-size: 1.15rem;
		letter-spacing: -0.02em;
	}

	.list {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 8px;
	}

	.user__link {
		color: rgba(255, 255, 255, 0.9);
		text-decoration: none;
	}

	.user__link:hover {
		text-decoration: underline;
		text-decoration-color: rgba(82, 255, 213, 0.5);
	}

	.user__handle {
		font-family: var(--mono);
		font-size: 0.98rem;
	}

	.user {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.user__status {
		min-width: 150px;
		max-width: 200px;
		font-size: 0.8rem;
		padding: 4px 8px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.18);
		background: rgba(0, 0, 0, 0.4);
		color: rgba(255, 255, 255, 0.9);
	}

	.footer {
		padding: 0 18px 20px;
		display: grid;
		place-items: center;
	}

	.footer__text {
		margin: 0;
		color: rgba(255, 255, 255, 0.56);
		max-width: 1050px;
		width: 100%;
		font-size: 0.95rem;
		padding: 0 clamp(0px, 4vw, 38px);
	}
</style>
