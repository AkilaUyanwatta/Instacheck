---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Instacheck</title>
	</head>
	<body>
		<main class="page" data-app-root data-view="summary">
			<header class="hero">
				<div class="hero__top">
					<div class="brand">
						<div class="brand__mark" aria-hidden="true">IC</div>
						<div class="brand__name">Instacheck</div>
					</div>
					<div class="hero__hint">All processing happens locally in your browser.</div>
				</div>
				<h1 class="hero__title">Visualize your Instagram export</h1>
				<p class="hero__subtitle">
					Upload the ZIP you downloaded from Instagram. We’ll find
					<code>connections/followers_and_following</code> and compute the diffs.
				</p>
				<div class="drop">
					<label class="drop__label">
						<input class="drop__input" data-zip-input type="file" accept=".zip,application/zip" />
						<span class="drop__cta">Choose export ZIP</span>
						<span class="drop__meta">.zip</span>
					</label>
					<div class="drop__status" data-status></div>
					<div class="drop__error" data-error></div>
				</div>

				<div class="exchange" data-exchange>
					<div class="exchange__title">Status export/import</div>

					<div class="exchange__actions">
						<button type="button" class="exchange__btn" data-export-map>
							Export
						</button>

						<label class="exchange__btn exchange__btn--secondary">
							Import file
							<input data-import-map-file-input type="file" accept="application/json,.json" hidden />
						</label>
					</div>

					<div class="exchange__import">
						<label class="exchange__replace">
							<input type="checkbox" data-import-map-replace-checkbox checked />
							<span>Replace existing `instacheck:` status</span>
						</label>

						<div class="exchange__text">
							<button
								type="button"
								class="exchange__btn exchange__btn--secondary"
								data-import-map-from-text
							>
								Select JSON file
							</button>
						</div>
					</div>
				</div>
			</header>

			<section class="results" data-results>
				<nav class="nav">
					<a class="nav__link" href="#summary" data-nav-link="summary" aria-current="true">
						<span class="nav__label">Basic summary</span>
					</a>
					<a class="nav__link" href="#not-following-back" data-nav-link="not-following-back">
						<span class="nav__label">Not following back</span>
						<span class="nav__pill"><span data-count="not-following-back">0</span></span>
					</a>
					<a class="nav__link" href="#fans" data-nav-link="fans">
						<span class="nav__label">Fans (they follow you)</span>
						<span class="nav__pill"><span data-count="fans">0</span></span>
					</a>
					<a class="nav__link" href="#unfollowed" data-nav-link="unfollowed">
						<span class="nav__label">Unfollowed users</span>
						<span class="nav__pill"><span data-count="unfollowed">0</span></span>
					</a>
				</nav>

				<div class="panels">
					<section class="panel" data-panel="summary">
						<div class="panel__grid">
							<div class="stat">
								<div class="stat__label">Followers</div>
								<div class="stat__value" data-count="followers">—</div>
							</div>
							<div class="stat">
								<div class="stat__label">Following</div>
								<div class="stat__value" data-count="following">—</div>
							</div>
							<div class="stat">
								<div class="stat__label">Mutuals</div>
								<div class="stat__value" data-count="mutual">—</div>
							</div>
						</div>
					</section>

					<section class="panel" data-panel="not-following-back">
						<h2 class="panel__title">People you follow who don’t follow you back</h2>
						<ol class="list" data-list="not-following-back"></ol>
					</section>

					<section class="panel" data-panel="fans">
						<h2 class="panel__title">People who follow you but you don’t follow back</h2>
						<ol class="list" data-list="fans"></ol>
					</section>

					<section class="panel" data-panel="unfollowed">
						<h2 class="panel__title">Accounts you unfollowed (from export)</h2>
						<ol class="list" data-list="unfollowed"></ol>
					</section>
				</div>
			</section>

			<footer class="footer">
				<p class="footer__text">
					Expected files: <code>connections/followers_and_following/followers_1.json</code> and
					<code>connections/followers_and_following/following.json</code>.
				</p>
			</footer>
		</main>

		<script type="module" src="/src/scripts/app.js"></script>
	</body>
</html>

<style is:global>
	:root {
		--bg: #07060a;
		--ink: rgba(255, 255, 255, 0.92);
		--muted: rgba(255, 255, 255, 0.68);
		--faint: rgba(255, 255, 255, 0.12);
		--faint2: rgba(255, 255, 255, 0.08);
		--edge: rgba(255, 255, 255, 0.18);
		--accent: #52ffd5;
		--accent2: #ff4dd8;
		--warn: #ff4d6d;
		--paper: rgba(255, 255, 255, 0.03);
		--paper2: rgba(255, 255, 255, 0.06);
		--shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
		--radius: 18px;
		--radius2: 26px;
		--mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New',
			monospace;
		--sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	html,
	body {
		height: 100%;
	}

	body {
		margin: 0;
		font-family: var(--sans);
		color: var(--ink);
		background: radial-gradient(1200px 600px at 16% 18%, rgba(82, 255, 213, 0.12), transparent 60%),
			radial-gradient(900px 540px at 84% 16%, rgba(255, 77, 216, 0.1), transparent 62%),
			radial-gradient(1100px 700px at 60% 90%, rgba(255, 77, 109, 0.08), transparent 60%),
			linear-gradient(180deg, #06050a 0%, #07060a 30%, #06060b 100%);
	}

	code {
		font-family: var(--mono);
		font-size: 0.92em;
		color: rgba(255, 255, 255, 0.86);
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		padding: 0.12rem 0.35rem;
		border-radius: 0.5rem;
	}

	.page {
		min-height: 100%;
		display: grid;
		grid-template-rows: auto 1fr auto;
	}

	.hero {
		padding: clamp(22px, 4vw, 52px) clamp(18px, 4vw, 56px) 22px;
		max-width: 1050px;
		width: 100%;
		margin: 0 auto;
	}

	.hero__top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 24px;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.brand__mark {
		width: 40px;
		height: 40px;
		border-radius: 14px;
		display: grid;
		place-items: center;
		font-weight: 800;
		letter-spacing: -0.08em;
		background: linear-gradient(135deg, rgba(82, 255, 213, 0.18), rgba(255, 77, 216, 0.16));
		border: 1px solid rgba(255, 255, 255, 0.14);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
	}

	.brand__name {
		font-weight: 760;
		letter-spacing: -0.035em;
	}

	.hero__hint {
		color: var(--muted);
		font-size: 0.95rem;
	}

	.hero__title {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.2rem);
		letter-spacing: -0.045em;
		line-height: 1.05;
	}

	.hero__subtitle {
		margin: 14px 0 0;
		color: var(--muted);
		max-width: 70ch;
		line-height: 1.5;
	}

	.drop {
		margin-top: 20px;
		padding: 14px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--radius2);
		box-shadow: var(--shadow);
		backdrop-filter: blur(10px);
	}

	.drop__label {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 10px;
		cursor: pointer;
		user-select: none;
	}

	.drop__input {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	.drop__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 14px;
		border-radius: 16px;
		background: linear-gradient(135deg, rgba(82, 255, 213, 0.14), rgba(255, 77, 216, 0.12));
		border: 1px solid rgba(255, 255, 255, 0.14);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.drop__meta {
		font-family: var(--mono);
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.72);
		padding: 8px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(0, 0, 0, 0.16);
	}

	.drop__status {
		margin-top: 10px;
		color: rgba(255, 255, 255, 0.75);
		font-size: 0.95rem;
		min-height: 1.2em;
	}

	.drop__error {
		margin-top: 8px;
		color: var(--warn);
		font-size: 0.95rem;
		line-height: 1.3;
		white-space: pre-wrap;
		display: none;
	}

	.drop__error[data-has-error] {
		display: block;
	}

	.exchange {
		margin-top: 16px;
		padding: 14px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--radius2);
		box-shadow: var(--shadow);
		backdrop-filter: blur(10px);
	}

	.exchange__title {
		font-weight: 760;
		letter-spacing: -0.03em;
		margin-bottom: 10px;
	}

	.exchange__actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 10px;
	}

	.exchange__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 12px 14px;
		border-radius: 16px;
		background: linear-gradient(135deg, rgba(82, 255, 213, 0.14), rgba(255, 77, 216, 0.12));
		border: 1px solid rgba(255, 255, 255, 0.14);
		font-weight: 700;
		letter-spacing: -0.02em;
		cursor: pointer;
	}

	.exchange__btn--secondary {
		background: rgba(255, 255, 255, 0.04);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.exchange__import {
		margin-top: 12px;
		display: grid;
		gap: 10px;
	}

	.exchange__replace {
		display: flex;
		align-items: center;
		gap: 10px;
		color: rgba(255, 255, 255, 0.75);
	}

	.exchange__replace input {
		accent-color: var(--accent);
	}

	.exchange__text {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 10px;
	}

	.exchange__text textarea {
		width: 100%;
		color: rgba(255, 255, 255, 0.9);
		background: rgba(0, 0, 0, 0.2);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 16px;
		padding: 12px 14px;
		font-family: var(--mono);
		resize: vertical;
	}

	@media (max-width: 680px) {
		.exchange__text {
			grid-template-columns: 1fr;
		}
	}

	.results {
		max-width: 1050px;
		width: 100%;
		margin: 0 auto;
		padding: 18px clamp(18px, 4vw, 56px) clamp(34px, 5vw, 64px);
		display: none;
	}

	.results[data-has-results] {
		display: block;
	}

	.nav {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.nav__link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		color: rgba(255, 255, 255, 0.86);
		text-decoration: none;
		background: rgba(255, 255, 255, 0.04);
	}

	.nav__link[aria-current='true'] {
		border-color: rgba(82, 255, 213, 0.32);
		box-shadow: 0 0 0 2px rgba(82, 255, 213, 0.08);
		background: rgba(82, 255, 213, 0.06);
	}

	.nav__pill {
		font-family: var(--mono);
		font-size: 0.88rem;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(0, 0, 0, 0.2);
	}

	.panels {
		margin-top: 16px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--radius2);
		box-shadow: var(--shadow);
		overflow: hidden;
	}

	.panel {
		padding: clamp(14px, 2.5vw, 22px);
		display: none;
	}

	.page[data-view='summary'] .panel[data-panel='summary'] {
		display: block;
	}

	.page[data-view='not-following-back'] .panel[data-panel='not-following-back'] {
		display: block;
	}

	.page[data-view='fans'] .panel[data-panel='fans'] {
		display: block;
	}

	.page[data-view='unfollowed'] .panel[data-panel='unfollowed'] {
		display: block;
	}

	.panel__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 12px;
	}

	@media (max-width: 680px) {
		.hero__top {
			flex-direction: column;
			align-items: flex-start;
		}

		.panel__grid {
			grid-template-columns: 1fr;
		}
	}

	.stat {
		border-radius: var(--radius);
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(0, 0, 0, 0.14);
		padding: 14px 14px 16px;
	}

	.stat__label {
		color: rgba(255, 255, 255, 0.68);
		font-size: 0.95rem;
		letter-spacing: -0.01em;
	}

	.stat__value {
		margin-top: 10px;
		font-size: 2.1rem;
		letter-spacing: -0.05em;
		font-weight: 780;
	}

	.panel__title {
		margin: 0 0 12px;
		font-size: 1.15rem;
		letter-spacing: -0.02em;
	}

	.list {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0;
	}

	.user__link {
		color: rgba(255, 255, 255, 0.9);
		text-decoration: none;
	}

	.user__link:hover {
		text-decoration: underline;
		text-decoration-color: rgba(82, 255, 213, 0.5);
	}

	.user__handle {
		font-family: var(--mono);
		font-size: 0.98rem;
	}

	.user {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 10px 4px;
	}

	.list > li.user:not(:last-child) {
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
	}

	.status {
		position: relative;
		display: inline-flex;
	}

	.status__current {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.04);
		color: rgba(255, 255, 255, 0.9);
		cursor: pointer;
		user-select: none;
		transition: transform 80ms ease, border-color 140ms ease, background 140ms ease, box-shadow 140ms ease;
	}

	.status__label {
		font-family: var(--mono);
		font-size: 0.85rem;
		white-space: nowrap;
	}

	.status__caret {
		width: 10px;
		height: 7px;
		background-image: url("data:image/svg+xml,%3Csvg width='10' height='7' viewBox='0 0 10 7' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L5 5.5L9 1.5' stroke='white' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
		background-repeat: no-repeat;
		background-size: contain;
		opacity: 0.95;
	}

	.status__current:focus-visible {
		outline: none;
		box-shadow: 0 0 0 2px rgba(82, 255, 213, 0.7);
	}

	.status__current:hover {
		transform: translateY(-1px);
	}

	.status__menu {
		position: absolute;
		right: 0;
		top: calc(100% + 10px);
		min-width: 240px;
		padding: 10px;
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(0, 0, 0, 0.72);
		backdrop-filter: blur(10px);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
		display: none;
		gap: 8px;
		z-index: 5;
	}

	.status__menu:not([hidden]) {
		display: grid;
	}

	.status__option {
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		padding: 10px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.04);
		color: rgba(255, 255, 255, 0.92);
		cursor: pointer;
		user-select: none;
		font-family: var(--mono);
		font-size: 0.85rem;
		transition: transform 80ms ease, border-color 140ms ease, background 140ms ease;
	}

	.status__option:hover {
		transform: translateY(-1px);
	}

	.status__option[aria-selected='true'] {
		box-shadow: 0 0 0 2px rgba(82, 255, 213, 0.12);
	}

	/* Current status colors */
	.status[data-status='open'] .status__current {
		border-color: rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.035);
		color: rgba(255, 255, 255, 0.78);
	}

	.status[data-status='in progress'] .status__current {
		border-color: rgba(82, 255, 213, 0.7);
		background-image: linear-gradient(135deg, rgba(82, 255, 213, 0.2), rgba(0, 180, 255, 0.24));
		background-origin: border-box;
	}

	.status[data-status='on hold'] .status__current {
		border-color: rgba(255, 196, 61, 0.9);
		background-image: linear-gradient(135deg, rgba(255, 196, 61, 0.24), rgba(255, 140, 0, 0.26));
		background-origin: border-box;
	}

	.status[data-status='attention requred'] .status__current {
		border-color: rgba(255, 77, 109, 0.9);
		background-image: linear-gradient(135deg, rgba(255, 77, 109, 0.28), rgba(255, 196, 61, 0.22));
		background-origin: border-box;
	}

	.status[data-status='done'] .status__current {
		border-color: rgba(82, 255, 213, 0.9);
		background-image: linear-gradient(135deg, rgba(82, 255, 213, 0.26), rgba(82, 255, 150, 0.28));
		background-origin: border-box;
		color: rgba(0, 20, 10, 0.95);
	}

	/* Option colors */
	.status__option[data-status-option='open'] {
		background: rgba(255, 255, 255, 0.035);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.status__option[data-status-option='in progress'] {
		border-color: rgba(82, 255, 213, 0.65);
		background-image: linear-gradient(135deg, rgba(82, 255, 213, 0.18), rgba(0, 180, 255, 0.2));
		background-origin: border-box;
	}

	.status__option[data-status-option='on hold'] {
		border-color: rgba(255, 196, 61, 0.9);
		background-image: linear-gradient(135deg, rgba(255, 196, 61, 0.2), rgba(255, 140, 0, 0.22));
		background-origin: border-box;
	}

	.status__option[data-status-option='attention requred'] {
		border-color: rgba(255, 77, 109, 0.9);
		background-image: linear-gradient(135deg, rgba(255, 77, 109, 0.24), rgba(255, 196, 61, 0.2));
		background-origin: border-box;
	}

	.status__option[data-status-option='done'] {
		border-color: rgba(82, 255, 213, 0.9);
		background-image: linear-gradient(135deg, rgba(82, 255, 213, 0.22), rgba(82, 255, 150, 0.24));
		background-origin: border-box;
		color: rgba(0, 20, 10, 0.95);
	}

	.footer {
		padding: 0 18px 20px;
		display: grid;
		place-items: center;
	}

	.footer__text {
		margin: 0;
		color: rgba(255, 255, 255, 0.56);
		max-width: 1050px;
		width: 100%;
		font-size: 0.95rem;
		padding: 0 clamp(0px, 4vw, 38px);
	}
</style>
